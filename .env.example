# =========================================================================
# BOLOS ALLEY OS — Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local
# =========================================================================

# ---- Supabase (required) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server-only, never expose to browser

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=bolos-jeddah

# ---- Phase 3: Payments (Moyasar) — fill when Phase 3 begins ----
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=

# ---- Phase 4: AI + WhatsApp — fill when Phase 4 begins ----
OPENAI_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---- IFTTT smart lights (per-branch keys live in DB; this is fallback) ----
IFTTT_DEFAULT_KEY=
